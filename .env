# Application
APP_NAME=ekyc-platform
APP_ENV=development
APP_PORT=8080
APP_HOST=0.0.0.0

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=ekyc_user
DB_PASSWORD=ekyc_pass
DB_NAME=ekyc_db
DB_SSLMODE=disable
DB_MAXCONNS=25
DB_MINCONNS=5

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass
REDIS_DB=0

# JWT
JWT_SECRET=change-this-to-a-secure-random-secret-min-32-chars
JWT_ACCESSTOKENEXPIRY=15m
JWT_REFRESHTOKENEXPIRY=168h

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
